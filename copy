include:
  - database/docker-compose.yml
  

services:
  nginx:
    container_name: nginx
    build: ./nginx
    ports:
      - "80:80"
    networks:
      - backend_network
      - frontend_network
    depends_on:
      - backend

  backend:
    container_name: backend
    build: ./backend
    depends_on:
      database:
        condition: service_healthy

    environment:
      - PORT=3000
      - DB_PORT=5432
      - DB_HOST=database
      - DB_DATABASE=${POSTGRES_DB}
      - DB_NAME=${POSTGRES_USER}
      - DB_PASS=${POSTGRES_PASSWORD}
    expose:
      - 3000
    networks:
      - backend_network
      - db_network

  frontend:
    container_name: frontend
    build: ./frontend
    expose:
      - "8080"
    networks:
      - frontend_network


networks:
  backend_network:
  
  db_network:
    internal: true

  frontend_network:

  database-network:

